# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/
.venv/
venv/
env/

# Environment
.env

# Databases
database/*.db
database/*.db-shm
database/*.db-wal

# Media (user content — never commit)
media_library/
media/clips/
media/renders/
media/previews/
media/audio/
media/thumbs/

# Logs
logs/
*.log

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# Test / coverage
.pytest_cache/
.coverage
htmlcov/

# Frontend build artifacts (keep source, ignore dist)
frontend/dist/
frontend/node_modules/
frontend/test-results/

# Tor bundle (local binary, not committed)
tor-bundle/

# Downloads (MMI debug/history)
downloads/

# Media root (catch-all for any media/ files not covered above)
media/
