# Kairos environment variables
# Copy to .env and fill in values before running.

KAIROS_PORT=8400

# Absolute path to media library root (leave blank to use project default: ./media_library)
KAIROS_MEDIA_ROOT=

# Hugging Face token (required for pyannote diarization in later phases)
HF_TOKEN=

# LLM provider for clip analysis: "ollama" (local) or "mission_control" (routed)
LLM_PROVIDER=ollama

# Ollama settings (used when LLM_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# Mission Control settings (used when LLM_PROVIDER=mission_control)
MC_HOST=http://localhost:8860
# Model ID in LiteLLM format — leave empty to let MC's adaptive router choose
# Examples: anthropic/claude-sonnet-4-6, google/gemini-2.5-flash, ollama/qwen2.5:32b
MC_MODEL_ID=

# Whisper transcription settings (Phase 2+)
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE=float16
